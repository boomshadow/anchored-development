<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}{% if title != site.title %} — {{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}">

  <!-- Open Graph -->
  <!-- TODO: Replace og:image with a 1200x630 landscape image for better social previews -->
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:image" content="{{ site.url }}/img/anchor-1000.webp">
  <meta property="og:image:width" content="1000">
  <meta property="og:image:height" content="1000">
  <meta property="og:image:type" content="image/webp">
  <meta property="og:image:alt" content="Anchor icon representing the Anchored Development framework">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ site.title }}">
  <meta property="og:locale" content="en_US">

  <!-- Preconnect to Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <!-- Fonts: Playfair Display (headings), Libre Baskerville (body), Jost (nav/labels) -->
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">

  <link rel="icon" type="image/webp" href="/img/anchor-128.webp">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <header class="site-header">
    <nav class="site-nav">
      <a href="/" class="nav-link{% if page.url === '/' %} nav-link--active{% endif %}">Home</a>
      <a href="/getting-started/" class="nav-link{% if page.url === '/getting-started/' %} nav-link--active{% endif %}">Getting Started</a>
      <a href="/colophon/" class="nav-link{% if page.url === '/colophon/' %} nav-link--active{% endif %}">Colophon</a>
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="footer-content">
      <p class="footer-license">
        Specification and website licensed under <a href="https://creativecommons.org/licenses/by-sa/4.0/">CC BY-SA 4.0</a>.
        Code licensed under <a href="https://www.mozilla.org/en-US/MPL/2.0/">MPL 2.0</a>.
      </p>
      <p class="footer-repo">
        <a href="https://github.com/boomshadow/anchored-development">View on GitHub</a>
      </p>
    </div>
  </footer>

</body>
</html>
